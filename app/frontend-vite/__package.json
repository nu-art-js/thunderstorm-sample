{
  "name": "@app/frontend-vite",
  "version": "{{APP_VERSION}}",
  "private": true,
  "description": "Frontend Vite app (Firebase Hosting)",
  "keywords": [
    "TacB0sS",
    "frontend",
    "vite",
    "react",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nu-art-js/thunderstorm-template.git"
  },
  "license": "Apache-2.0",
  "author": "TacB0sS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "start": "vite"
  },
  "dependencies": {
    "@nu-art/ts-common": "?",
    "@nu-art/thunder-core": "?",
    "@nu-art/thunder-routing": "?",
    "@nu-art/thunder-ui-modules": "?",
    "@nu-art/thunder-widgets": "?",
    "@nu-art/ts-styles": "?",
    "react": "?",
    "react-dom": "?",
    "react-router-dom": "?"
  },
  "devDependencies": {
    "@types/react": "?",
    "@types/react-dom": "?",
    "@types/react-router-dom": "?",
    "@vitejs/plugin-react": "?",
    "sass": "?",
    "vite": "?",
    "vite-plugin-node-polyfills": "?",
    "vite-plugin-svgr": "?"
  },
  "unitConfig": {
    "hasSelfHotReload": true,
    "servingPort": 8001,
    "type": "vite-hosting",
    "label": "Frontend Vite",
    "envs": {
      "local": {
        "config": {
          "configUrl": "http://127.0.0.1:8004/_config/frontend/manager.json?ns=demo-project-default-rtdb"
        },
        "projectId": "demo-project"
      }
    }
  },
  "type": "module",
  "publishConfig": {
    "directory": "dist"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  }
}
